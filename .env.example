# Copy this file to an untracked .env file for local development.
# Never commit real tokens, passwords, signing keys, database URLs, or user data.

# Server
HOST=127.0.0.1
PORT=8000
RUNTIME_DATA_PATH=./runtime-data/runtime.json
JOB_SPRINT_RUNTIME_DB_PATH=./runtime-data/job-sprint.sqlite
DATABASE_URL=sqlite://./runtime-data/job-sprint.sqlite
JOB_SPRINT_MAX_BODY_BYTES=1048576

# Application authentication
JOB_SPRINT_AUTH_DISABLED=false
JOB_SPRINT_AUTH_USER=your_local_user
JOB_SPRINT_AUTH_PASSWORD=your_local_password
# Prefer a hash in shared environments.
JOB_SPRINT_AUTH_PASSWORD_SHA256=your_password_sha256_here
JOB_SPRINT_SESSION_SECRET=replace_with_at_least_32_random_characters
JOB_SPRINT_COOKIE_SECURE=false
JOB_SPRINT_LOGIN_RATE_LIMIT_MAX=8
JOB_SPRINT_LOGIN_RATE_LIMIT_WINDOW_MS=900000

# Multi-user and bearer-token auth. Use either inline JSON or an external file.
JOB_SPRINT_USERS_JSON=[{"username":"demo","passwordHash":"sha256_hash_here","role":"coach","dataScope":"demo"}]
JOB_SPRINT_USERS_FILE=/absolute/path/outside/repo/users.json
JOB_SPRINT_BEARER_TOKENS_JSON=[{"name":"local-tool","tokenHash":"sha256_hash_here","role":"coach","dataScope":"demo","expiresAt":"2099-01-01T00:00:00.000Z"}]
JOB_SPRINT_BEARER_TOKENS_FILE=/absolute/path/outside/repo/bearer-tokens.json

# AI provider. Leave token empty to use local fallback behavior.
ANTHROPIC_BASE_URL=https://your-anthropic-compatible-endpoint.example.com
ANTHROPIC_AUTH_TOKEN=replace-with-your-token
ANTHROPIC_MODEL=your_model_name_here
AI_PROVIDER_TIMEOUT_MS=30000
CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1

# Speech-to-text provider
ASR_PROVIDER=none
ASR_AUTH_TOKEN=your_asr_token_here
ASR_MAX_AUDIO_BYTES=8388608

# Remote validation and Android WebView URL. Use your own staging domain.
JOB_SPRINT_REMOTE_BASE_URL=https://your-staging-domain.example.com
JOB_SPRINT_ANDROID_WEBVIEW_URL=https://your-staging-domain.example.com/job-sprint/react/index.html
JOB_SPRINT_ANDROID_CDP_PORT=9224
JOB_SPRINT_ANDROID_FUNCTIONAL_MODE=remote

# Android release signing. Keep keystores and passwords outside this repository.
JOB_SPRINT_ANDROID_KEYSTORE=/absolute/path/outside/repo/android-release-keystore.p12
JOB_SPRINT_ANDROID_STORE_PASSWORD=your_store_password_here
JOB_SPRINT_ANDROID_KEY_ALIAS=your_key_alias_here
JOB_SPRINT_ANDROID_KEY_PASSWORD=your_key_password_here
JOB_SPRINT_ANDROID_RELEASE_CERT_SHA256=your_release_cert_sha256_here
